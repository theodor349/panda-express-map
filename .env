# EU5 mod environment variables
# Copy this file to .env.local and set your own paths there.

# Path to the EU5 game installation directory (contains main_menu/, in_game/, etc.)
EU5_GAME_PATH=C:\Program Files (x86)\Steam\steamapps\common\Europa Universalis V\game

# Path to the mod root directory (contains main_menu/, scripts/, etc.)
EU5_MOD_PATH=C:\Users\YourName\Documents\Paradox Interactive\Europa Universalis V\mod\Panda Express Map
